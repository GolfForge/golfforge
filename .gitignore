# =====================================================================
# Python
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
dist/
build/
.coverage
.coverage.*
htmlcov/

# =====================================================================
# UE5  (Epic's standard project gitignore, lightly trimmed)
# =====================================================================
# UE5 creates the project under engine/<ProjectName>/, so we use ** patterns
# to match build artifacts regardless of nesting depth.

# Build artifacts and per-machine state
engine/**/Binaries/
engine/**/Build/
engine/**/Intermediate/
engine/**/Saved/
engine/**/DerivedDataCache/
engine/**/.vs/
engine/**/.idea/
engine/**/.vscode/
engine/**/*.opensdf
engine/**/*.sdf
engine/**/*.suo
engine/**/*.user
engine/**/*.VC.db
engine/**/*.VC.opendb
engine/**/*.xcworkspace/
engine/**/*.xcodeproj/

# Visual Studio / Rider project files (regenerated by UE)
engine/**/*.sln
engine/**/*.vcxproj
engine/**/*.vcxproj.filters

# Third-party MCP plugin clones — contributors clone these locally per docs.
# We don't vendor upstream code; see docs/windows-setup.md for clone steps.
engine/**/Plugins/UnrealClaudeMCP/
engine/UnrealClaudeMCP-upstream/

# Quixel Megascans / Megaplant / Fab — re-downloadable for free per machine
# via the UE5.7 Fab plugin (Quixel Bridge is deprecated; Megascans now ships
# through Fab → /Game/Fab/...). Skipping ~2 GB of LFS bloat. docs/ue5-cookbook.md
# lists which assets are referenced so a fresh clone knows what to re-download
# before opening BethPageBlack.
engine/**/Content/Megaplant_Library/
engine/**/Content/Megascans/
engine/**/Content/Fab/
# Marketplace foliage packs that import to their own top-level Content
# folder (not under /Fab) - same re-downloadable rationale, huge LFS cost
# (PC3D Kentucky Bluegrass = 112 meshes + 546 MIs + Pivot-Painter textures).
engine/**/Content/PC3D_Kentucky_Bluegrass_v14/

# World Partition external actors/objects. Our course maps are deliberately
# non-WP Basic levels (see M0 'Save As off Open World Template' pitfall), so
# these only ever appear from third-party template demo maps (e.g. the FP
# template's Lvl_FirstPerson). We don't ship those demo levels.
engine/**/Content/__ExternalActors__/
engine/**/Content/__ExternalObjects__/

# Per-machine Claude Code MCP config (copy .mcp.json.example to .mcp.json and edit)
.mcp.json

# Local packaging helper (hardcodes this machine's UE/repo paths) + packaged build output.
# GOL-49 will add a committed, path-agnostic packaging script for the real release.
engine/scripts/package-windows.bat
/Build/
.claude/

# Crash reports
engine/**/CrashReportClient/

# Mac
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# =====================================================================
# Pipeline outputs (regenerable; LFS handles the ones we want to commit)
# =====================================================================
# Course output directories are git-tracked, but the raw cache files are not
courses/**/osm_raw.json
courses/**/dem.tif

# Local OS junk
*.swp
*.swo
*~
